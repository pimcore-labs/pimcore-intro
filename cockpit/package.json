{
  "name": "pimcore-cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "predev": "npm run build:data",
    "prebuild": "npm run build:data",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "npm run build:data && tsc -b && BUILD_TARGET=single vite build",
    "build:single:twig": "npm run build:single && tsx scripts/twigify.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts --ext .ts,.tsx"
  },
  "dependencies": {
    "d3-shape": "^3.2.0",
    "framer-motion": "^11.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
